---
---

<section class="px-6 py-24 bg-[#FDFBF7] relative">
	<div class="max-w-[1000px] mx-auto">
		<div class="text-center mb-20">
			<span class="text-gold font-bold uppercase tracking-[0.2em] text-xs mb-3 block">El Viaje</span>
			<h2 class="text-4xl md:text-5xl font-serif text-text-main">La Ruta de 7 Fases</h2>
			<p class="mt-4 text-text-light font-light text-lg">Un proceso lineal y acumulativo diseñado para ejecutivos.</p>
		</div>
		<div class="relative space-y-16 pl-4 md:pl-0">
			<div class="absolute left-4 md:left-1/2 top-4 bottom-4 w-px bg-gold/20 -translate-x-1/2 hidden md:block"></div>
			<div class="absolute left-[19px] top-4 bottom-4 w-px bg-gold/20 md:hidden"></div>
			
			<!-- Fase 01 -->
			<div class="relative flex flex-col md:flex-row items-center justify-between group">
				<div class="hidden md:block w-1/2 text-right pr-16">
					<h3 class="text-3xl font-serif text-primary/30 group-hover:text-primary transition-colors mb-2">Fase 01</h3>
					<h4 class="text-xl font-bold text-text-main mb-2">Auditoría del Sistema Nervioso</h4>
					<p class="text-sm text-text-light font-light leading-relaxed">Evaluación profunda de tu estado actual mediante métricas de VFC y patrones de sueño.</p>
				</div>
				<div class="absolute left-[11px] md:left-1/2 -translate-x-1/2 w-4 h-4 rounded-full bg-cream border-2 border-gold z-10 group-hover:scale-125 transition-transform"></div>
				<div class="w-full md:w-1/2 pl-12 md:pl-16 md:hidden">
					<span class="text-xs text-primary font-bold tracking-widest uppercase mb-1 block">Fase 01</span>
					<h4 class="text-xl font-serif text-text-main mb-2">Auditoría del Sistema Nervioso</h4>
					<p class="text-sm text-text-light font-light">Evaluación profunda de tu estado actual mediante métricas de VFC.</p>
				</div>
				<div class="hidden md:block w-1/2 pl-16"></div>
			</div>

			<!-- Fase 02 -->
			<div class="relative flex flex-col md:flex-row items-center justify-between group">
				<div class="hidden md:block w-1/2 pr-16"></div>
				<div class="absolute left-[11px] md:left-1/2 -translate-x-1/2 w-4 h-4 rounded-full bg-cream border-2 border-gold z-10 group-hover:scale-125 transition-transform"></div>
				<div class="w-full md:w-1/2 pl-12 md:pl-16">
					<span class="md:hidden text-xs text-primary font-bold tracking-widest uppercase mb-1 block">Fase 02</span>
					<h3 class="hidden md:block text-3xl font-serif text-primary/30 group-hover:text-primary transition-colors mb-2">Fase 02</h3>
					<h4 class="text-xl font-serif md:font-bold text-text-main mb-2">Desintoxicación de Dopamina</h4>
					<p class="text-sm text-text-light font-light leading-relaxed">Reset de los receptores de recompensa para recuperar el foco sostenido y reducir la ansiedad latente.</p>
				</div>
			</div>

			<!-- Fase 03 -->
			<div class="relative flex flex-col md:flex-row items-center justify-between group">
				<div class="hidden md:block w-1/2 text-right pr-16">
					<h3 class="text-3xl font-serif text-primary/30 group-hover:text-primary transition-colors mb-2">Fase 03</h3>
					<h4 class="text-xl font-bold text-text-main mb-2">Regulación Somática Basal</h4>
					<p class="text-sm text-text-light font-light leading-relaxed">Implementación de herramientas físicas para elevar tu "Ventana de Tolerancia" al estrés.</p>
				</div>
				<div class="absolute left-[11px] md:left-1/2 -translate-x-1/2 w-4 h-4 rounded-full bg-cream border-2 border-gold z-10 group-hover:scale-125 transition-transform"></div>
				<div class="w-full md:w-1/2 pl-12 md:pl-16 md:hidden">
					<span class="text-xs text-primary font-bold tracking-widest uppercase mb-1 block">Fase 03</span>
					<h4 class="text-xl font-serif text-text-main mb-2">Regulación Somática Basal</h4>
					<p class="text-sm text-text-light font-light">Implementación de herramientas físicas para elevar tu "Ventana de Tolerancia".</p>
				</div>
				<div class="hidden md:block w-1/2 pl-16"></div>
			</div>

			<!-- Fase 04 -->
			<div class="relative flex flex-col md:flex-row items-center justify-between group">
				<div class="hidden md:block w-1/2 pr-16"></div>
				<div class="absolute left-[11px] md:left-1/2 -translate-x-1/2 w-4 h-4 rounded-full bg-cream border-2 border-gold z-10 group-hover:scale-125 transition-transform"></div>
				<div class="w-full md:w-1/2 pl-12 md:pl-16">
					<span class="md:hidden text-xs text-primary font-bold tracking-widest uppercase mb-1 block">Fase 04</span>
					<h3 class="hidden md:block text-3xl font-serif text-primary/30 group-hover:text-primary transition-colors mb-2">Fase 04</h3>
					<h4 class="text-xl font-serif md:font-bold text-text-main mb-2">Reestructuración Cognitiva</h4>
					<p class="text-sm text-text-light font-light leading-relaxed">Identificación y desactivación de creencias limitantes arraigadas que disparan la respuesta de lucha/huida.</p>
				</div>
			</div>

			<!-- Fase 05 -->
			<div class="relative flex flex-col md:flex-row items-center justify-between group">
				<div class="hidden md:block w-1/2 text-right pr-16">
					<h3 class="text-3xl font-serif text-primary/30 group-hover:text-primary transition-colors mb-2">Fase 05</h3>
					<h4 class="text-xl font-bold text-text-main mb-2">Protocolos de Liderazgo</h4>
					<p class="text-sm text-text-light font-light leading-relaxed">Diseño de rutinas específicas para antes, durante y después de momentos de alta exigencia.</p>
				</div>
				<div class="absolute left-[11px] md:left-1/2 -translate-x-1/2 w-4 h-4 rounded-full bg-cream border-2 border-gold z-10 group-hover:scale-125 transition-transform"></div>
				<div class="w-full md:w-1/2 pl-12 md:pl-16 md:hidden">
					<span class="text-xs text-primary font-bold tracking-widest uppercase mb-1 block">Fase 05</span>
					<h4 class="text-xl font-serif text-text-main mb-2">Protocolos de Liderazgo</h4>
					<p class="text-sm text-text-light font-light">Diseño de rutinas específicas para momentos de alta exigencia.</p>
				</div>
				<div class="hidden md:block w-1/2 pl-16"></div>
			</div>

			<!-- Fase 06 -->
			<div class="relative flex flex-col md:flex-row items-center justify-between group">
				<div class="hidden md:block w-1/2 pr-16"></div>
				<div class="absolute left-[11px] md:left-1/2 -translate-x-1/2 w-4 h-4 rounded-full bg-cream border-2 border-gold z-10 group-hover:scale-125 transition-transform"></div>
				<div class="w-full md:w-1/2 pl-12 md:pl-16">
					<span class="md:hidden text-xs text-primary font-bold tracking-widest uppercase mb-1 block">Fase 06</span>
					<h3 class="hidden md:block text-3xl font-serif text-primary/30 group-hover:text-primary transition-colors mb-2">Fase 06</h3>
					<h4 class="text-xl font-serif md:font-bold text-text-main mb-2">Integración en Alta Presión</h4>
					<p class="text-sm text-text-light font-light leading-relaxed">Simulaciones y aplicación en tiempo real en tu entorno laboral actual.</p>
				</div>
			</div>

			<!-- Fase 07 -->
			<div class="relative flex flex-col md:flex-row items-center justify-between group">
				<div class="hidden md:block w-1/2 text-right pr-16">
					<h3 class="text-3xl font-serif text-primary/30 group-hover:text-primary transition-colors mb-2">Fase 07</h3>
					<h4 class="text-xl font-bold text-text-main mb-2">Mantenimiento y Autonomía</h4>
					<p class="text-sm text-text-light font-light leading-relaxed">Creación de tu "Manual de Usuario" personal para sostener los resultados sin dependencia externa.</p>
				</div>
				<div class="absolute left-[11px] md:left-1/2 -translate-x-1/2 w-4 h-4 rounded-full bg-cream border-2 border-gold z-10 group-hover:scale-125 transition-transform"></div>
				<div class="w-full md:w-1/2 pl-12 md:pl-16 md:hidden">
					<span class="text-xs text-primary font-bold tracking-widest uppercase mb-1 block">Fase 07</span>
					<h4 class="text-xl font-serif text-text-main mb-2">Mantenimiento y Autonomía</h4>
					<p class="text-sm text-text-light font-light">Creación de tu "Manual de Usuario" personal para sostener los resultados.</p>
				</div>
				<div class="hidden md:block w-1/2 pl-16"></div>
			</div>
		</div>
	</div>
</section>
