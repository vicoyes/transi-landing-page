<section class="px-6 py-20 bg-cream-dark border-t border-gold/10">
	<div class="max-w-[1120px] mx-auto">
		<div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8">
			<div class="flex flex-col items-center justify-center p-8 bg-cream rounded-[2rem] border border-gold/10 shadow-sm hover:shadow-md transition-shadow">
				<span class="material-symbols-outlined text-gold text-3xl mb-3">calendar_month</span>
				<p class="text-[10px] uppercase tracking-widest text-text-light mb-1 font-bold">Duración</p>
				<p class="font-serif text-xl text-text-main">7 Semanas</p>
			</div>
			<div class="flex flex-col items-center justify-center p-8 bg-cream rounded-[2rem] border border-gold/10 shadow-sm hover:shadow-md transition-shadow">
				<span class="material-symbols-outlined text-gold text-3xl mb-3">video_camera_front</span>
				<p class="text-[10px] uppercase tracking-widest text-text-light mb-1 font-bold">Sesiones</p>
				<p class="font-serif text-xl text-text-main">7 Online (1:1)</p>
			</div>
			<div class="flex flex-col items-center justify-center p-8 bg-cream rounded-[2rem] border border-gold/10 shadow-sm hover:shadow-md transition-shadow">
				<span class="material-symbols-outlined text-gold text-3xl mb-3">chat</span>
				<p class="text-[10px] uppercase tracking-widest text-text-light mb-1 font-bold">Soporte</p>
				<p class="font-serif text-xl text-text-main">WhatsApp/Video</p>
			</div>
			<div class="flex flex-col items-center justify-center p-8 bg-cream rounded-[2rem] border border-gold/10 shadow-sm hover:shadow-md transition-shadow">
				<span class="material-symbols-outlined text-gold text-3xl mb-3">timer</span>
				<p class="text-[10px] uppercase tracking-widest text-text-light mb-1 font-bold">Práctica</p>
				<p class="font-serif text-xl text-text-main">5-15 min/día</p>
			</div>
		</div>
	</div>
</section>
