<section class="relative pt-32 pb-20 md:pt-48 md:pb-32 px-6 overflow-hidden">
	<!-- Background decorative elements -->
	<div class="fixed inset-0 pointer-events-none z-0 overflow-hidden">
		<svg class="absolute -top-[10%] -right-[10%] w-[60%] h-[60%] opacity-[0.03] text-gold animate-pulse duration-[10000ms]" viewBox="0 0 100 100">
			<circle cx="50" cy="50" fill="none" r="40" stroke="currentColor" stroke-width="0.5"></circle>
			<circle cx="50" cy="50" fill="none" r="30" stroke="currentColor" stroke-width="0.2"></circle>
			<path d="M50 10 Q 90 10 90 50" fill="none" stroke="currentColor" stroke-width="0.2"></path>
		</svg>
		<svg class="absolute top-[40%] -left-[10%] w-[40%] h-[40%] opacity-[0.05] text-primary" viewBox="0 0 200 200">
			<path d="M40,100 C20,80 20,40 50,40 C80,40 80,80 60,100 C80,120 80,160 50,160 C20,160 20,120 40,100 Z" fill="currentColor"></path>
			<path d="M160,100 C180,80 180,40 150,40 C120,40 120,80 140,100 C120,120 120,160 150,160 C180,160 180,120 160,100 Z" fill="currentColor"></path>
		</svg>
	</div>

	<div class="max-w-[1280px] mx-auto flex flex-col md:flex-row items-center gap-16 relative">
		<div class="flex-1 flex flex-col gap-8 z-10 md:pr-10">
			<div class="inline-flex items-center gap-2 px-4 py-1.5 bg-primary/5 border border-primary/10 rounded-full w-fit">
				<span class="material-symbols-outlined text-primary text-sm">verified</span>
				<span class="text-primary text-xs font-bold uppercase tracking-widest">Programa Ejecutivo High-End</span>
			</div>
			<h1 class="text-5xl md:text-6xl lg:text-7xl font-serif font-medium text-text-main leading-[1.15] tracking-tight">
				El Activo más Crítico de tu Empresa es tu <br/>
				<span class="text-primary italic relative inline-block">
					Sistema Nervioso
					<svg class="absolute w-full h-4 -bottom-2 left-0 text-gold/60 -z-10" preserveAspectRatio="none" viewBox="0 0 100 10">
						<path d="M0 5 Q 50 12 100 5" fill="none" stroke="currentColor" stroke-width="3"></path>
					</svg>
				</span>
			</h1>
			<p class="text-lg md:text-xl text-text-light font-light leading-relaxed max-w-[580px]">
				Transforma el estrés crónico en presencia ejecutiva. Una metodología basada en neurociencia aplicada y psicología somática para líderes que buscan serenidad real.
			</p>
			<div class="flex flex-col sm:flex-row gap-6 mt-4">
				<div class="flex flex-col gap-2">
					<a href="/reserva" class="bg-primary hover:bg-primary/90 text-white text-base tracking-wider uppercase px-10 py-4 rounded-full transition-all shadow-xl shadow-primary/25 flex items-center justify-center gap-3 group font-serif w-fit">
						Reservar Sesión Gratuita
						<span class="material-symbols-outlined group-hover:translate-x-1 transition-transform font-thin">arrow_forward</span>
					</a>
					<p class="text-sm text-text-light font-light">Sesión de diagnóstico de 15 min. 100% gratis · Sin compromiso.</p>
				</div>
			</div>
			<div class="flex items-center gap-4 text-sm text-text-light pt-4 border-t border-gold/10 w-fit">
				<div class="flex -space-x-3">
					<div class="w-10 h-10 rounded-full border-2 border-cream bg-gray-200 bg-cover bg-center warm-filter" style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuA7yMHl97qRGgw8zZ1GMRlnY1eR-gC-GSerT1h_164CKPGZDSjkRcK7sjUua-1fWO4Hn-jQKLqUUh8vqv4Y3rVXFE8vVmuf_hBf8gUtNsxGN6PJzPfFOSGe-JHnr_Mp11c25PFSSwW8tPKDqer8sgQqjTVLQ8stUrJgxkq2Z6W3t1oH2l1ZM0iAXaq2zSHNBVaDfc9jLOudG0cJfI3t-fOPVQjXwHG_y9VOUABaVv_7kjIOEykcvrBn30qEfp0CMZQxJOMJQecPgYk')"></div>
					<div class="w-10 h-10 rounded-full border-2 border-cream bg-gray-200 bg-cover bg-center warm-filter" style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuBXCoWPVs9ptpZIb_vCOZM5X7DzszXnYYZGEmUTOxyR6N0KkIGKqcqDYEAY734LjGEha0JKUAksksh2h9atZ_yb35qMindG4-2iTzJkqrVVb-8p-tYeQ-rEkM6EpQlnv8GeBUx5AhlLzBTlpAxlQ_p0ZPy93UV9DpFNEjvDMCe1qwg-vE0n68CCY9_MzWyfpKl1hlGh95A7mJzpsUeNpPPosIVkRPzVZuZTAlykHxRZ1oCxRNiAif_g3xhdHZbp7EPUTNNty6spcvw')"></div>
					<div class="w-10 h-10 rounded-full border-2 border-cream bg-gray-200 bg-cover bg-center warm-filter" style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuDWQaLeOYEoBsEm3TWjwX6KBnDR2yeOTI7MC72Zr1D7AOvJZrkDXXOrG3-6UlCdLPkDWIFYAxwdUgIrdoaWc3rU5vDzaxIFOrmenkJEp381fQ4-qEEBh1O6Lp3lgXXmoLiS3QufCCOGERCUHde4IivmKV8CcJxp0ZvFXmB8YXgC3OoG6OL216aV6Blma46Aqxa9kzQUuKV16qkU3G-Q4KS7SFUQFigNum3ixwI6PWQvcU5Myq_Oh9MFtLv8gfG6cjzXfJT6-_gbGLQ')"></div>
				</div>
				<div class="flex flex-col">
					<div class="flex text-gold">
						<span class="material-symbols-outlined text-sm">star</span>
						<span class="material-symbols-outlined text-sm">star</span>
						<span class="material-symbols-outlined text-sm">star</span>
						<span class="material-symbols-outlined text-sm">star</span>
						<span class="material-symbols-outlined text-sm">star</span>
					</div>
					<span class="font-light text-xs tracking-wide">Elegido por +500 ejecutivos</span>
				</div>
			</div>
		</div>
		<div class="flex-1 w-full relative perspective-1000">
			<div class="absolute top-10 right-10 w-full h-full border border-gold/30 rounded-t-[10rem] rounded-b-[2rem] -z-10 transform translate-x-4 translate-y-4"></div>
			<div class="absolute -bottom-10 -left-10 w-32 h-32 bg-gold/10 rounded-full blur-2xl -z-10"></div>
			<div class="w-full aspect-[4/5] md:aspect-[3.5/4.5] bg-cover bg-center rounded-t-[10rem] rounded-b-[2rem] shadow-2xl relative overflow-hidden warm-filter transform transition-transform duration-700 hover:scale-[1.01]" style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuBXNslIxCZIW9ay_4DpRiSuKq_pq6tJ4PrWBPebb6bOSfFVFZmYqE8BlF2FB6VYdO01PyiuR0u_QkQNrTbcRFT0OWj8pSJoPI4ct6YeYGYaiuB-jYbsaPBTSRJS8J8V1h5kT479wajQUq4lEW_yU6w_mH1EXHuVT8v_2JHJkjrWVp3d-AyEPRlXrDfexV0c_hAvaNy0lzWmna3RGYfQBG6ckYp_z9EEk5T12fMDxhpZeTAPVwtA7JdnpFpUBRHZ50UXgOy4FnYysIE')">
				<div class="absolute inset-0 bg-gradient-to-t from-primary/20 via-transparent to-transparent opacity-60"></div>
				<div class="absolute bottom-8 left-8 right-8 bg-white/90 backdrop-blur-md p-5 rounded-2xl shadow-lg border border-white/40">
					<div class="flex items-center gap-4">
						<div class="bg-primary/10 p-2.5 rounded-full text-primary">
							<span class="material-symbols-outlined font-light">self_improvement</span>
						</div>
						<div>
							<p class="text-[10px] text-text-light uppercase tracking-wider font-bold">Estado Actual</p>
							<p class="text-sm font-serif text-text-main">Regulación Nerviosa: <span class="italic text-primary">Activa</span></p>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>
