---
import logo from '../assets/logo-horizontal.png.webp';
---

<header class="fixed top-0 w-full z-50 transition-all duration-300 bg-cream/90 backdrop-blur-md border-b border-gold/10">
	<div class="px-6 md:px-12 py-5 max-w-[1400px] mx-auto flex items-center justify-between">
		<a href="/" class="flex items-center gap-3">
			<img src={logo.src} alt="Liderar desde la Serenidad" class="h-8 w-auto object-contain" width={logo.width} height={logo.height} />
		</a>
		<a href="/reserva" class="hidden md:inline-flex items-center bg-primary hover:bg-primary/90 text-white text-sm tracking-widest uppercase px-8 py-3 rounded-full transition-all shadow-lg shadow-primary/20 hover:shadow-primary/30 font-serif">
			Sesión Gratuita
		</a>
	</div>
</header>
