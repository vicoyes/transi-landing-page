---
import '../styles/global.css';
import ogImage from '../assets/transi.jpg';

interface Props {
	title?: string;
	description?: string;
	/** Ruta o URL de la imagen para compartir (og:image). Por defecto: transi.jpg */
	image?: string;
}

const { title = "Liderar desde la Serenidad", description = "Transforma el estrés crónico en presencia ejecutiva. Una metodología basada en neurociencia aplicada y psicología somática para líderes que buscan serenidad real.", image } = Astro.props;

const site = Astro.site?.href ?? '';
const canonical = site ? new URL(Astro.url.pathname, site).href : '';
const ogImagePath = image ?? ogImage.src;
const ogImageUrl = site ? new URL(ogImagePath.startsWith('/') ? ogImagePath : `/${ogImagePath}`, site).href : ogImagePath;
const ogImageWidth = image ? undefined : ogImage.width;
const ogImageHeight = image ? undefined : ogImage.height;
---

<!doctype html>
<html class="light scroll-smooth" lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		{canonical ? <link rel="canonical" href={canonical} /> : null}

		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImageUrl} />
		{ogImageWidth ? <meta property="og:image:width" content={String(ogImageWidth)} /> : null}
		{ogImageHeight ? <meta property="og:image:height" content={String(ogImageHeight)} /> : null}
		{canonical ? <meta property="og:url" content={canonical} /> : null}
		<meta property="og:locale" content="es_ES" />
		<meta property="og:site_name" content="Liderar desde la Serenidad" />

		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageUrl} />

		<!-- Google Fonts -->
		<link href="https://fonts.googleapis.com" rel="preconnect" />
		<link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect" />
		<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Lato:wght@300;400;700&display=swap" rel="stylesheet" />
		<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
	</head>
	<body class="bg-cream text-text-main font-sans overflow-x-hidden antialiased selection:bg-primary/20 selection:text-primary">
		<slot />
	</body>
</html>
