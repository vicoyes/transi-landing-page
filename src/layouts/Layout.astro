---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
}

const { title = "Liderar desde la Serenidad", description = "Transforma el estrés crónico en presencia ejecutiva. Una metodología basada en neurociencia aplicada y psicología somática para líderes que buscan serenidad real." } = Astro.props;
---

<!doctype html>
<html class="light scroll-smooth" lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
		
		<!-- Google Fonts -->
		<link href="https://fonts.googleapis.com" rel="preconnect" />
		<link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect" />
		<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Lato:wght@300;400;700&display=swap" rel="stylesheet" />
		<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
	</head>
	<body class="bg-cream text-text-main font-sans overflow-x-hidden antialiased selection:bg-primary/20 selection:text-primary">
		<slot />
	</body>
</html>
