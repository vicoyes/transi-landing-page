---
import Layout from '../layouts/Layout.astro';
import HeaderMetodo from '../components/HeaderMetodo.astro';
import Footer from '../components/Footer.astro';
import BotonVolver from '../components/BotonVolver.astro';
import HeroMetodo from '../components/HeroMetodo.astro';
import IngenieriaPersonal from '../components/IngenieriaPersonal.astro';
import TresPilares from '../components/TresPilares.astro';
import RutaFases from '../components/RutaFases.astro';
import DosFormasOperar from '../components/DosFormasOperar.astro';
import DetallesPrograma from '../components/DetallesPrograma.astro';
import CTAAgendar from '../components/CTAAgendar.astro';
---

<Layout
	title="Metodología - Liderar desde la Serenidad"
	description="Conoce el método: neurociencia aplicada, psicología somática y protocolos de alta eficacia. Liderazgo como estado biológico. Agenda tu sesión de diagnóstico gratuita."
>
	<div class="relative z-10 flex flex-col min-h-screen w-full">
		<!-- Background decorative elements -->
		<div class="fixed inset-0 pointer-events-none z-0 overflow-hidden">
			<svg class="absolute -top-[10%] -right-[10%] w-[60%] h-[60%] opacity-[0.03] text-gold animate-pulse duration-[10000ms]" viewBox="0 0 100 100">
				<circle cx="50" cy="50" fill="none" r="40" stroke="currentColor" stroke-width="0.5"></circle>
				<circle cx="50" cy="50" fill="none" r="30" stroke="currentColor" stroke-width="0.2"></circle>
				<path d="M50 10 Q 90 10 90 50" fill="none" stroke="currentColor" stroke-width="0.2"></path>
			</svg>
			<svg class="absolute top-[40%] -left-[10%] w-[40%] h-[40%] opacity-[0.05] text-primary" viewBox="0 0 200 200">
				<path d="M40,100 C20,80 20,40 50,40 C80,40 80,80 60,100 C80,120 80,160 50,160 C20,160 20,120 40,100 Z" fill="currentColor"></path>
				<path d="M160,100 C180,80 180,40 150,40 C120,40 120,80 140,100 C120,120 120,160 150,160 C180,160 180,120 160,100 Z" fill="currentColor"></path>
			</svg>
		</div>

		<HeaderMetodo />
		<BotonVolver />
		<main>
			<HeroMetodo />
			<IngenieriaPersonal />
			<TresPilares />
			<RutaFases />
			<DosFormasOperar />
			<DetallesPrograma />
			<CTAAgendar />
		</main>
		<Footer />
	</div>
</Layout>
